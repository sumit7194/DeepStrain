# --- Python / OS ---
__pycache__/
*.pyc
.DS_Store

# --- virtual environments (regenerate per sub-project; encode absolute paths) ---
.venv/

# --- runtime / scratch ---
.dashboard.pid
*.tmp
*.tmp.*

# --- training logs ---
sbi-logs/

# --- trained model weights: regenerable by training; *_history.json IS kept ---
*.pt

# --- bulky result arrays: the small result JSONs + PNGs ARE committed as the
#     scientific record; verify.sh's one tiny scorer .npy is whitelisted ---
*.parquet
*.npy
!echoes/results/07_ml_scorer.npy

# --- per-run heartbeat caches ---
**/results/progress/

# --- raw strain anywhere (regenerable from GWOSC; e.g. spike/output/) ---
*.hdf5

# --- large regenerable data (re-fetch from GWOSC / rebuild), keep the manifest ---
**/data/**
!**/data/manifest.json
